{
  "openapi": "3.0.0",
  "info": {
    "title": "Voters System API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "User Authentication"
    },
    {
      "name": "Voters",
      "description": "Approved / Registered Voters"
    },
    {
      "name": "Pending",
      "description": "Pending Approval System"
    }
  ],
  "paths": {
    "/api/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login result" }
        }
      }
    },

    "/api/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User created" }
        }
      }
    },

    "/api/voters": {
      "get": {
        "tags": ["Voters"],
        "summary": "Get all approved voters",
        "responses": {
          "200": { "description": "List of voters" }
        }
      },
      "post": {
        "tags": ["Voters"],
        "summary": "Add voter",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstname": { "type": "string" },
                  "lastname": { "type": "string" },
                  "address": { "type": "string" },
                  "age": { "type": "integer" },
                  "birthdate": { "type": "string" },
                  "gender": { "type": "string" },
                  "precinct_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Voter added" }
        }
      }
    },

    "/api/voters/{id}": {
      "put": {
        "tags": ["Voters"],
        "summary": "Update voter",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "tags": ["Voters"],
        "summary": "Delete voter",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },

    "/api/voters/pending": {
      "get": {
        "tags": ["Pending"],
        "summary": "Get all pending voters",
        "responses": {
          "200": { "description": "List of pending voters" }
        }
      }
    },

    "/api/voters/accept/{id}": {
      "put": {
        "tags": ["Pending"],
        "summary": "Approve voter",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Voter approved" }
        }
      }
    },

    "/api/voters/reject/{id}": {
      "put": {
        "tags": ["Pending"],
        "summary": "Reject voter",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Voter rejected" }
        }
      }
    },

    "/api/precincts": {
      "get": {
        "tags": ["Voters"],
        "summary": "Get precincts",
        "responses": {
          "200": { "description": "List of precincts" }
        }
      }
    }
  }
}